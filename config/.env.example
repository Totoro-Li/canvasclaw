# CanvasClaw — fill these in and save as canvasclaw/config/.env
# Any OpenAI-compatible endpoint works (DeepSeek / OpenRouter / self-hosted proxy / OpenAI).

OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-...
LLM_MODEL=deepseek-chat
# Optional: a cheaper model just for routing (defaults to LLM_MODEL)
ROUTER_MODEL=deepseek-chat
# Vision-capable model for slide OCR / formula pages (defaults to LLM_MODEL)
VISION_MODEL=

# --- optional overrides (sane defaults in config.py) ---
# EMBED_MODEL=BAAI/bge-small-zh-v1.5
# EMBED_DEVICE=cuda
# MAX_LECTURES_FANOUT=5
# REDIS_URL=redis://localhost:6379/0
